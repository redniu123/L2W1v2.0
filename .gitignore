# 忽略所有 .md 文件，但保留 README.md
*.md
!README.md

# 忽略 docs 文件夹
docs/

# 忽略 archive 文件夹
archive/

# 忽略模型文件
models/
*.tar.gz
*.tar
*.pdmodel
*.pdiparams
*.pdopt

# 忽略结果文件
results/

# 允许 GitHub 中转云端结果
!cloud_result_sync/
!cloud_result_sync/**

# 忽略日志
log_output/
*.log

# 忽略 __pycache__
__pycache__/
*.pyc
*.pyo

# 忽略临时测试文件
scripts/_test_api.py
scripts/_debug_agentb.py
scripts/_models.json
scripts/_test_model.json
nul
fix_out.txt

# 忽略原始大数据（图像）
data/geo/geotext/

# 忽略 key 文件（安全）
key.txt

# 忽略数据集划分文件（大文件，本地生成）
data/raw/
